    "Draw one card from either the deck or the discard pile, then discard one card from your hand." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk et kort fra enten bunken eller aflægningsbunken, og læg derefter et kort fra din hånd."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe eine Karte vom Stapel oder Ablagestapel und lege dann eine Karte aus deiner Hand ab."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Roba una carta del mazo o de la pila de descartes, luego descarta una carta de tu mano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piochez une carte dans la pioche ou la défausse, puis défaussez une carte de votre hand."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "या तो गड्डी या ढेर से एक कार्ड निकालें, फिर अपने हाथ से एक कार्ड फेंकें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pesca una carta dal mazzo o dalla pila degli scarti, quindi scartane una dalla tua mano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "山札または捨て札から1枚引き、手札から1枚捨てます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "더미나 버려진 카드 더미에서 카드 한 장을 가져온 뒤, 손패에서 카드 한 장을 버리세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trekk ett kort fra enten kortstokken eller kastbunken, og kast deretter ett kort fra hånden din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pak één kaart van de trekstapel of de aflegstapel en gooi vervolgens één kaart uit je hand weg."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compre uma carta do baralho ou da pilha de descarte e, em seguida, descarte uma carta da sua mão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Возьмите одну карту из колоды или стопки сброса, затем сбросьте одну карту из руки."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dra ett kort från antingen kortleken eller högen med slängda kort, och släng sedan ett kort från din hand."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desteden veya ıskarta destesinden bir kart çekin, ardından elinizden bir kart atın."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rút một lá bài từ xấp bài hoặc xấp bài bỏ, sau đó đánh một lá bài từ tay bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从牌堆或弃牌堆摸一张牌，然后从手牌中弃掉一张牌。"
