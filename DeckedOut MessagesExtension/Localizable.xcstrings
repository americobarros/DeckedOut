    "The player with the lowest total score wins. If there is a tie, the player who went out first loses." : {
      "comment" : "Explanation of the scoring system in Golf.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spilleren med den laveste samlede score vinder. I tilfælde af uafgjort taber den spiller, der gik ud først."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Spieler mit der niedrigsten Gesamtpunktzahl gewinnt. Bei einem Gleichstand verliert der Spieler, der als Erster fertig war."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gana el jugador con la puntuación total más baja. En caso de empate, pierde el jugador que terminó primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le joueur avec le score total le plus bas gagne. En cas d'égalité, le joueur qui a terminé en premier perd."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सबसे कम कुल स्कोर वाला खिलाड़ी जीतता है। यदि टाई होता है, तो सबसे पहले गेम खत्म करने वाला खिलाड़ी हार जाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vince il giocatore con il punteggio totale più basso. In caso di pareggio, perde il giocatore che ha chiuso per primo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "合計スコアが最も低いプレイヤーの勝利です。同点の場合は、最初にあがったプレイヤーの負けとなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "총점이 가장 낮은 플레이어가 승리합니다. 동점일 경우, 먼저 게임을 끝낸 플레이어가 패배합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spilleren med lavest totalpoengsum vinner. Ved uavgjort taper spilleren som gikk ut først."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De speler met de laagste totaalscore wint. Bij een gelijkspel verliest de speler die als eerste uitging."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O jogador com a menor pontuação total vence. Em caso de empate, o jogador que terminou primeiro perde."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Побеждает игрок с наименьшим общим счетом. В случае ничьей проигрывает тот, кто закончил игру первым."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spelaren med lägst totalpoäng vinner. Vid oavgjort förlorar den spelare som gick ut först."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En düşük toplam puana sahip olan oyuncu kazanır. Beraberlik durumunda, oyunu ilk bitiren oyuncu kaybeder."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Người chơi có tổng điểm thấp nhất sẽ thắng. Nếu hòa, người chơi kết thúc trước sẽ thua."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "总分最低的玩家获胜。如果出现平局，最先结束的玩家输。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "總分最低的玩家獲勝。如果出現平局，最先結束的玩家輸。"
          }
        }
      }
    },
