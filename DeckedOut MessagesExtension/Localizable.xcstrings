    "Another player joined at the same time you did. Please try again." : {
      "comment" : "A message displayed when another player attempts to join a game at the same time the user is trying to join.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En anden spiller deltog på samme tid som dig. Prøv venligst igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein anderer Spieler ist zur gleichen Zeit beigetreten wie du. Bitte versuche es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otro jugador se unió al mismo tiempo que tú. Por favor, inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un autre joueur a rejoint en même temps que vous. Veuillez réessayer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक अन्य खिलाड़ी उसी समय शामिल हुआ जब आप हुए थे। कृपया पुनः प्रयास करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un altro giocatore si è unito nel tuo stesso momento. Per favore riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他のプレイヤーがあなたと同時に参加しました。もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 플레이어가 귀하와 동시에 참여했습니다. 다시 시도해 주세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En annen spiller ble med på samme tid som deg. Vennligst prøv igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een andere speler is tegelijk met jou toegetreden. Probeer het opnieuw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Outro jogador entrou ao mesmo tempo que você. Por favor, tente novamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Другой игрок присоединился одновременно с вами. Пожалуйста, попробуйте еще раз."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En annan spelare gick med samtidigt som du. Vänligen försök igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Başka bir oyuncu sizinle aynı anda katıldı. Lütfen tekrar deneyin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Một người chơi khác đã tham gia cùng lúc với bạn. Vui lòng thử lại."
