    "Arrange your cards into sets (same rank) or runs (consecutive cards of the same suit) of 3 or more." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arranger dine kort i sæt (samme værdi) eller rækker (tre eller flere kort i rækkefølge i samme kulør)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ordne deine Karten in Sätzen (gleicher Rang) oder Folgen (aufeinanderfolgende Karten derselben Farbe) von 3 oder mehr an."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organiza tus cartas en grupos (mismo valor) o escaleras (cartas consecutivas del mismo palo) de 3 o más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organisez vos cartes en brelans (même rang) ou en suites (cartes consécutives de la même couleur) de 3 ou plus."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने कार्डों को 3 या अधिक के सेट (समान रैंक) या रन (एक ही सूट के लगातार कार्ड) में व्यवस्थित करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disponi le tue carte in gruppi (stesso valore) o scale (carte consecutive dello stesso seme) di 3 o più."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3枚以上のセット（同じランク）またはラン（同じスートの連続したカード）にカードを並べましょう"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카드를 같은 숫자의 세트나 같은 무늬의 연속된 숫자(런) 3장 이상으로 구성하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorter kortene dine i sett (samme rang) eller serier (sammenhengende kort i samme farge) på 3 eller flere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leg je kaarten in sets (dezelfde waarde) of rijtjes (opeenvolgend, zelfde kleur) van 3 of meer."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organize suas cartas em jogos (mesmo valor) ou sequências (cartas consecutivas do mesmo naipe) de 3 ou mais."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Собирайте карты в сеты (одного ранга) или ряды (последовательные карты одной масти) по 3 и более."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samla dina kort i serier (samma valör) eller sekvenser (efterföljande kort i samma färg) om 3 eller fler."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kartlarınızı 3 veya daha fazla set (aynı değer) veya seri (aynı gruptan ardışık kartlar) halinde düzenleyin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sắp xếp các lá bài của bạn thành các bộ (cùng hạng) hoặc sảnh (các lá bài liên tiếp cùng chất) từ 3 lá trở lên."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将你的手牌组合成3张或以上的同点牌组，或同花顺（同花色且连续的牌）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將您的卡片排列成3張或更多張的組（同等級）或順（同花色連續）。"
          }
        }
      }
    },
