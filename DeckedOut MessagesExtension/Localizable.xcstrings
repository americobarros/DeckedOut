    "Be the first player to get rid of all of your cards!" : {
      "comment" : "Description of how to win in Golf.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vær den første spiller til at komme af med alle dine kort!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei der erste Spieler, der alle seine Karten loswird!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Sé el primer jugador en deshacerte de todas tus cartas!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soyez le premier joueur à vous débarrasser de toutes vos cartes !"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने सभी कार्डों से छुटकारा पाने वाले पहले खिलाड़ी बनें!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sii il primo giocatore a sbarazzarsi di tutte le proprie carte!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いち早く手札をすべて使い切りましょう！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가장 먼저 모든 카드를 없애는 플레이어가 되세요!"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vær den første spilleren som blir kvitt alle kortene dine!"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wees de eerste speler die al zijn kaarten kwijtraakt!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seja o primeiro jogador a se livrar de todas as suas cartas!"
          }
        },
        "ru" : {
