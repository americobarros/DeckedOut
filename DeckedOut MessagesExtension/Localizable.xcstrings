    "Draw a card from the deck or the discard pile, then swap it with any card in your grid. The swapped card is discarded." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk et kort fra bunken eller aflægningsbunken, og byt det derefter ud med et valgfrit kort i dit gitter. Det udskiftede kort lægges i aflægningsbunken."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe eine Karte vom Stapel oder vom Ablagestapel und tausche sie gegen eine beliebige Karte in deinem Raster aus. Die getauschte Karte wird abgelegt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Roba una carta del mazo o de la pila de descartes, luego cámbiala por cualquier carta de tu cuadrícula. La carta intercambiada se descarta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piochez une carte dans la pioche ou la défausse, puis échangez-la avec n'importe quelle carte de votre grille. La carte échangée est défaussée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "गड्डी या ढेर से एक कार्ड निकालें, फिर उसे अपने ग्रिड के किसी भी कार्ड से बदलें। बदला गया कार्ड फेंक दिया जाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pesca una carta dal mazzo o dalla pila degli scarti, quindi scambiala con qualsiasi carta della tua griglia. La carta sostituita viene scartata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "山札または捨て札から1枚引き、自分のグリッドのカードと交換します。交換されたカードは捨て札となります"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카드 더미나 버려진 카드 더미에서 카드 한 장을 뽑아 내 그리드의 카드와 교체하세요. 교체된 카드는 버려집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trekk et kort fra kortstokken eller kastbunken, og bytt det ut med et valgfritt kort i rutenettet ditt. Kortet du bytter ut, kastes."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pak een kaart van de stapel of de aflegstapel en ruil deze vervolgens om met een willekeurige kaart in je raster. De omgeruilde kaart wordt weggegooid."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compre uma carta do baralho ou da pilha de descarte e, em seguida, troque-a por qualquer carta na sua grade. A carta trocada é descartada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Возьмите карту из колоды или стопки сброса, затем замените ею любую карту в вашей сетке. Замененная карта сбрасывается."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dra ett kort från kortleken eller högen med slängda kort och byt ut det mot valfritt kort i ditt rutnät. Det utbytta kortet slängs."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desteden veya ıskarta destesinden bir kart çekin, ardından bunu tablonuzdaki herhangi bir kartla değiştirin. Değiştirilen kart atılır."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rút một lá bài từ xấp bài hoặc xấp bài bỏ, sau đó hoán đổi nó với bất kỳ lá bài nào trong lưới của bạn. Lá bài được hoán đổi sẽ bị bỏ đi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从牌堆或弃牌堆摸一张牌，然后将其与你网格中的任意一张牌交换。换下的牌将被弃掉。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從牌堆或棄牌堆摸一張牌，然後將其與您網格中的任意一張牌交換。換下的牌將被棄掉。"
          }
        }
      }
    },
