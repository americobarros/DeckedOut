    "Swipe up or down to change game. Double tap to open the %@ menu." : {
      "comment" : "VoiceOver accessibility hint for the game-selection carousel, %@ is the selected game name",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stryg op eller ned for at skifte spil. Dobbelttryk for at åbne %@-menuen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wische nach oben oder unten, um das Spiel zu wechseln. Doppeltippe, um das %@-Menü zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza hacia arriba o abajo para cambiar de juego. Toca dos veces para abrir el menú de %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balayez vers le haut ou le bas pour changer de jeu. Appuyez deux fois pour ouvrir le menu %@."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "गेम बदलने के लिए ऊपर या नीचे स्वाइप करें। %@ मेनू खोलने के लिए डबल टैप करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scorri verso l'alto o il basso per cambiare gioco. Tocca due volte per aprire il menu di %@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上下にスワイプしてゲームを切り替えます。ダブルタップで%@のメニューを開きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위 또는 아래로 쓸어 게임을 변경하세요. 두 번 탭하여 %@ 메뉴를 엽니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sveip opp eller ned for å bytte spill. Dobbelttrykk for å åpne %@-menyen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veeg omhoog of omlaag om van spel te wisselen. Dubbeltik om het %@-menu te openen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deslize para cima ou para baixo para mudar de jogo. Toque duas vezes para abrir o menu %@."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проведите вверх или вниз, чтобы сменить игру. Дважды коснитесь, чтобы открыть меню %@."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svep upp eller ned för att byta spel. Dubbeltryck för att öppna %@-menyn."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oyunu değiştirmek için yukarı veya aşağı kaydırın. %@ menüsünü açmak için iki kez dokunun."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuốt lên hoặc xuống để đổi trò chơi. Nhấn đúp để mở menu %@."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "向上或向下滑动以更换游戏。轻点两下打开%@菜单。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "向上或向下滑動以更換遊戲。輕點兩下開啟%@選單。"
          }
        }
      }
    },
